# Polytex Configuration
# Copy to .env and adjust values

# Secret key for session encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# If not set, a key is auto-generated and stored in .secret_key
SECRET_KEY=

# Admin password (default: admin123 — CHANGE THIS!)
ADMIN_PASSWORD=admin123

# Set to 1 for development
FLASK_DEBUG=0
